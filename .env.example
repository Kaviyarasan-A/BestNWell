# Public site URL used for canonical links, sitemap, robots and OG metadata.
# Set this to your live domain in production (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://kaagamsoftware.com

# Google Search Console verification token (Settings > Ownership verification >
# HTML tag). Paste only the content="..." value here. Lets Google index you faster.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification token (optional).
NEXT_PUBLIC_BING_SITE_VERIFICATION=
